@model ProjectVitour.Dtos.ReviewDtos.CreateReviewDto

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Tur Yorumu Ekle</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <style>
        :root {
            --primary: #1a6b4a;
            --primary-dark: #134d36;
            --primary-light: #e8f5ef;
            --accent: #f4a623;
            --accent-hover: #e09418;
            --text-muted-custom: #6c757d;
            --card-shadow: 0 20px 60px rgba(0,0,0,0.1);
        }

        body {
            background: linear-gradient(135deg, #e8f5ef 0%, #d4edda 40%, #c8e6f5 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem 1rem;
        }

        .page-wrapper {
            width: 100%;
            max-width: 680px;
        }

        .brand-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .brand-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, var(--primary), #2d9e6e);
            border-radius: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 1rem;
            box-shadow: 0 8px 24px rgba(26,107,74,0.3);
        }

            .brand-icon i {
                font-size: 1.8rem;
                color: #fff;
            }

        .brand-header h1 {
            font-size: 1.75rem;
            font-weight: 700;
            color: #1a2e22;
            margin-bottom: 0.3rem;
        }

        .brand-header p {
            color: var(--text-muted-custom);
            font-size: 0.95rem;
        }

        .review-card {
            background: #fff;
            border-radius: 20px;
            padding: 2.5rem;
            box-shadow: var(--card-shadow);
            border: 1px solid rgba(255,255,255,0.8);
        }

        .form-label {
            font-weight: 600;
            color: #2c3e35;
            font-size: 0.9rem;
            margin-bottom: 0.5rem;
            display: flex;
            align-items: center;
            gap: 0.4rem;
        }

            .form-label i {
                color: var(--primary);
                font-size: 1rem;
            }

        .form-control, .form-select {
            border: 1.5px solid #dee2e6;
            border-radius: 10px;
            padding: 0.65rem 1rem;
            font-size: 0.95rem;
            transition: border-color 0.2s, box-shadow 0.2s;
            background-color: #fafafa;
        }

            .form-control:focus, .form-select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 3px rgba(26,107,74,0.12);
                background-color: #fff;
                outline: none;
            }

        textarea.form-control {
            resize: vertical;
            min-height: 130px;
        }

        .star-rating-label {
            display: flex;
            align-items: center;
            gap: 0.4rem;
            font-weight: 600;
            color: #2c3e35;
            font-size: 0.9rem;
            margin-bottom: 0.6rem;
        }

            .star-rating-label i {
                color: var(--primary);
            }

        .star-rating-wrapper {
            background: #fafafa;
            border: 1.5px solid #dee2e6;
            border-radius: 10px;
            padding: 0.5rem 1rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            transition: border-color 0.2s;
        }

            .star-rating-wrapper:hover {
                border-color: var(--primary);
            }

        .star-rating {
            display: flex;
            flex-direction: row-reverse;
            gap: 4px;
        }

            .star-rating input[type="radio"] {
                display: none;
            }

            .star-rating label {
                cursor: pointer;
                font-size: 1.8rem;
                color: #dee2e6;
                transition: color 0.15s, transform 0.15s;
                line-height: 1;
            }

                .star-rating label:hover,
                .star-rating label:hover ~ label,
                .star-rating input:checked ~ label {
                    color: var(--accent);
                }

                .star-rating label:hover {
                    transform: scale(1.2);
                }

            .star-rating input:checked + label {
                transform: scale(1.1);
            }

        .section-divider {
            border: none;
            border-top: 1.5px dashed #e9ecef;
            margin: 1.5rem 0;
        }

        .btn-submit {
            background: linear-gradient(135deg, var(--primary) 0%, #2d9e6e 100%);
            color: #fff;
            border: none;
            border-radius: 12px;
            padding: 0.85rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            width: 100%;
            transition: transform 0.2s, box-shadow 0.2s;
            box-shadow: 0 6px 20px rgba(26,107,74,0.3);
        }

            .btn-submit:hover {
                transform: translateY(-2px);
                box-shadow: 0 10px 28px rgba(26,107,74,0.4);
                color: #fff;
            }

        .tour-info-badge {
            background: var(--primary-light);
            border: 1px solid #a8d5bc;
            border-radius: 8px;
            padding: 0.5rem 0.9rem;
            font-size: 0.82rem;
            color: var(--primary);
            display: flex;
            align-items: center;
            gap: 0.4rem;
            margin-bottom: 1.5rem;
        }
    </style>
</head>
<body>

    <div class="page-wrapper">
        <div class="brand-header">
            <div class="brand-icon">
                <i class="bi bi-star-half"></i>
            </div>
            <h1>Tur Yorumu Ekle</h1>
            <p>Deneyiminizi 4 farklı kriterde değerlendirin</p>
        </div>

        <div class="review-card">

            <form asp-action="CreateReview" method="post" novalidate id="reviewForm">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                <input type="hidden" name="TourId" value="@Model?.TourId" />
                <input type="hidden" name="Score" value="0" />

                <div class="mb-4">
                    <label asp-for="NameSurname" class="form-label">
                        <i class="bi bi-person-fill"></i> Ad Soyad
                    </label>
                    <input asp-for="NameSurname" class="form-control" placeholder="Adınızı ve soyadınızı girin" required />
                </div>

                <div class="mb-4">
                    <label asp-for="Detail" class="form-label">
                        <i class="bi bi-chat-quote-fill"></i> Yorum Detayı
                    </label>
                    <textarea asp-for="Detail" class="form-control" placeholder="Tur deneyiminizi detaylı olarak anlatın..." required></textarea>
                </div>

                <hr class="section-divider" />
                <h6 class="mb-3 text-muted">Detaylı Değerlendirme</h6>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <div class="star-rating-label"><i class="bi bi-person-badge"></i> Rehber</div>
                        <div class="star-rating-wrapper">
                            <div class="star-rating">
                                <input type="radio" asp-for="GuideRating" id="gStar5" value="5" required /> <label for="gStar5">&#9733;</label>
                                <input type="radio" asp-for="GuideRating" id="gStar4" value="4" /> <label for="gStar4">&#9733;</label>
                                <input type="radio" asp-for="GuideRating" id="gStar3" value="3" /> <label for="gStar3">&#9733;</label>
                                <input type="radio" asp-for="GuideRating" id="gStar2" value="2" /> <label for="gStar2">&#9733;</label>
                                <input type="radio" asp-for="GuideRating" id="gStar1" value="1" /> <label for="gStar1">&#9733;</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="star-rating-label"><i class="bi bi-house-door"></i> Konaklama</div>
                        <div class="star-rating-wrapper">
                            <div class="star-rating">
                                <input type="radio" asp-for="AccommodationRating" id="aStar5" value="5" required /> <label for="aStar5">&#9733;</label>
                                <input type="radio" asp-for="AccommodationRating" id="aStar4" value="4" /> <label for="aStar4">&#9733;</label>
                                <input type="radio" asp-for="AccommodationRating" id="aStar3" value="3" /> <label for="aStar3">&#9733;</label>
                                <input type="radio" asp-for="AccommodationRating" id="aStar2" value="2" /> <label for="aStar2">&#9733;</label>
                                <input type="radio" asp-for="AccommodationRating" id="aStar1" value="1" /> <label for="aStar1">&#9733;</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="star-rating-label"><i class="bi bi-bus-front"></i> Ulaşım</div>
                        <div class="star-rating-wrapper">
                            <div class="star-rating">
                                <input type="radio" asp-for="TransportRating" id="tStar5" value="5" required /> <label for="tStar5">&#9733;</label>
                                <input type="radio" asp-for="TransportRating" id="tStar4" value="4" /> <label for="tStar4">&#9733;</label>
                                <input type="radio" asp-for="TransportRating" id="tStar3" value="3" /> <label for="tStar3">&#9733;</label>
                                <input type="radio" asp-for="TransportRating" id="tStar2" value="2" /> <label for="tStar2">&#9733;</label>
                                <input type="radio" asp-for="TransportRating" id="tStar1" value="1" /> <label for="tStar1">&#9733;</label>
                            </div>
                        </div>
                    </div>

                    <div class="col-md-6 mb-3">
                        <div class="star-rating-label"><i class="bi bi-cup-hot"></i> Konfor</div>
                        <div class="star-rating-wrapper">
                            <div class="star-rating">
                                <input type="radio" asp-for="ComfortRating" id="cStar5" value="5" required /> <label for="cStar5">&#9733;</label>
                                <input type="radio" asp-for="ComfortRating" id="cStar4" value="4" /> <label for="cStar4">&#9733;</label>
                                <input type="radio" asp-for="ComfortRating" id="cStar3" value="3" /> <label for="cStar3">&#9733;</label>
                                <input type="radio" asp-for="ComfortRating" id="cStar2" value="2" /> <label for="cStar2">&#9733;</label>
                                <input type="radio" asp-for="ComfortRating" id="cStar1" value="1" /> <label for="cStar1">&#9733;</label>
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="section-divider" />

                <div class="mb-4">
                    <label asp-for="ReviewDate" class="form-label">
                        <i class="bi bi-calendar3"></i> Yorum Tarihi
                    </label>
                    <input asp-for="ReviewDate" type="date" class="form-control" id="reviewDateInput" required />
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-submit">
                        <i class="bi bi-send-fill me-2"></i> Yorumu Kaydet
                    </button>
                </div>

            </form>
        </div>
    </div>

    <script>
        // Set today's date as default
        (function () {
            const dateInput = document.getElementById('reviewDateInput');
            if (dateInput && !dateInput.value) {
                const today = new Date();
                const yyyy = today.getFullYear();
                const mm = String(today.getMonth() + 1).padStart(2, '0');
                const dd = String(today.getDate()).padStart(2, '0');
                dateInput.value = `${yyyy}-${mm}-${dd}`;
            }
        })();
    </script>
</body>
</html>