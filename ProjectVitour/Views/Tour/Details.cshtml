@model ProjectVitour.Dtos.TourDtos.GetTourByIdDto
@{
    ViewData["Title"] = Model.Title;
    Layout = "~/Views/Shared/_VitourLayout.cshtml";
}

<section class="tour-single" style="margin-top: 130px; margin-bottom: 80px;">
    <div class="tf-container">
        <div class="row">
            <!-- SOL TARAF: İÇERİK VE SEKMELER -->
            <div class="col-lg-8">
                <div class="row">
                    <div class="col-lg-12">
                        <ul class="nav justify-content-between tab-tour-single" id="pills-tab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="pills-information-tab" data-bs-toggle="pill" data-bs-target="#pills-information" type="button" role="tab">
                                    <i class="icon-Vector-51"></i> Bilgi
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="pills-tour-planing-tab" data-bs-toggle="pill" data-bs-target="#pills-tour-planing" type="button" role="tab">
                                    <i class="icon-destination-2-1"></i> Program
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="pills-location-share-tab" data-bs-toggle="pill" data-bs-target="#pills-location-share" type="button" role="tab">
                                    <i class="icon-map-1"></i> Harita
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="pills-reviews-tab" data-bs-toggle="pill" data-bs-target="#pills-reviews" type="button" role="tab">
                                    <i class="icon-favourite-1"></i> Yorumlar
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="pills-gallery-tab" data-bs-toggle="pill" data-bs-target="#pills-gallery" type="button" role="tab">
                                    <i class="icon-gallery-1"></i> Galeri
                                </button>
                            </li>
                        </ul>
                    </div>
                </div>

                <div class="tab-content pd-main" id="pills-tabContent">
                    <!-- 1. INFORMATION -->
                    <div class="tab-pane fade show active" id="pills-information" role="tabpanel">
                        <div class="inner-heading mb-30">
                            <span class="feature">@Model.Badge</span>
                            <h2 class="title mt-2">@Model.Title</h2>
                            <ul class="flex-three list-wrap-heading mt-3">
                                <li class="flex-three"><i class="icon-time-left"></i> <span>@Model.DayCount Gün</span></li>
                                <li class="flex-three"><i class="icon-user"></i> <span>Kapasite: @Model.Capacity Kişi</span></li>
                                <li class="flex-three"><i class="icon-18"></i> <span>@Model.Location</span></li>
                            </ul>
                        </div>
                        <img src="@Model.CoverImageUrl" alt="@Model.Title" style="width:100%; height:450px; object-fit:cover; border-radius:15px; margin-bottom:30px;">
                        <div class="description-wrap">
                            <h4 class="mb-3">Tur Açıklaması</h4>
                            <p class="des">@Model.Description</p>
                        </div>
                    </div>

                    <!-- 2. TOUR PLANNING -->
                    <div class="tab-pane fade" id="pills-tour-planing" role="tabpanel">
                        <h3 class="title-plan mb-4">Günlük Tur Programı</h3>
                        @if (Model.TourPlans != null && Model.TourPlans.Count > 0)
                        {
                            foreach (var plan in Model.TourPlans)
                            {
                                <div class="tour-planing-section flex mb-4" style="background: #f9f9f9; padding: 20px; border-radius: 12px;">
                                    <div class="number-box flex-five" style="background:#1a6b4a; color:white; width:50px; height:50px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold; margin-right:20px;">@plan.DayNumber</div>
                                    <div class="content-box">
                                        <h5 class="title" style="font-weight:700;">@plan.Title</h5>
                                        <p class="des mt-2">@plan.Description</p>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    <!-- 3. LOCATION (PIXAR MAP) -->
                    <div class="tab-pane fade" id="pills-location-share" role="tabpanel">
                        <h3 class="title-location mb-4">Bölge Haritası (AI Pixar Style)</h3>
                        <div style="border-radius:20px; overflow:hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.1);">
                            <img src="@Model.MapLocationImageUrl" alt="Map" style="width:100%; height:auto;">
                        </div>
                    </div>

                    <!-- 4. REVIEWS -->
                    <div class="tab-pane fade" id="pills-reviews" role="tabpanel">
                        @{
                            var reviewList = Model.Reviews ?? new List<ProjectVitour.Dtos.ReviewDtos.ResultReviewByTourIdDto>();
                            var totalReviews = reviewList.Count;
                            double avgGuide = totalReviews > 0 ? reviewList.Average(x => x.GuideRating) : 0;
                            double avgAcc = totalReviews > 0 ? reviewList.Average(x => x.AccommodationRating) : 0;
                            double avgTrans = totalReviews > 0 ? reviewList.Average(x => x.TransportRating) : 0;
                            double avgComf = totalReviews > 0 ? reviewList.Average(x => x.ComfortRating) : 0;
                            double overallAvg = totalReviews > 0 ? (avgGuide + avgAcc + avgTrans + avgComf) / 4.0 : 0;
                        }
                        <h3 class="mb-4">Müşteri Yorumları</h3>
                        <div class="row align-items-center mb-5" style="background:#fcfcfc; padding:30px; border-radius:15px;">
                            <div class="col-md-4 text-center">
                                <h1 style="font-size:64px; color:#1a6b4a; font-weight:800;">@overallAvg.ToString("0.0")</h1>
                                <p>Genel Puan / 5.0</p>
                            </div>
                            <div class="col-md-8">
                                <div class="mb-2">Rehber: @avgGuide.ToString("0.0") <div class="progress"><div class="progress-bar bg-success" style="width:@(avgGuide*20)%"></div></div></div>
                                <div class="mb-2">Konaklama: @avgAcc.ToString("0.0") <div class="progress"><div class="progress-bar bg-success" style="width:@(avgAcc*20)%"></div></div></div>
                                <div class="mb-2">Ulaşım: @avgTrans.ToString("0.0") <div class="progress"><div class="progress-bar bg-success" style="width:@(avgTrans*20)%"></div></div></div>
                                <div class="mb-2">Konfor: @avgComf.ToString("0.0") <div class="progress"><div class="progress-bar bg-success" style="width:@(avgComf*20)%"></div></div></div>
                            </div>
                        </div>
                        @foreach (var item in reviewList)
                        {
                            <div class="mb-4 p-3 border-bottom">
                                <h6 style="font-weight:bold;">@item.NameSurname</h6>
                                <p>@item.Detail</p>
                                <small class="text-muted">@item.ReviewDate.ToString("dd MMM yyyy")</small>
                            </div>
                        }
                    </div>

                    <!-- 5. SHOT GALLERY -->
                    <div class="tab-pane fade" id="pills-gallery" role="tabpanel">
                        <h3 class="mb-4">Tur Galerisi</h3>
                        <div class="row g-3">
                            @if (Model.TourImages != null)
                            {
                                foreach (var img in Model.TourImages)
                                {
                                    <div class="col-md-4">
                                        <img src="@img.ImageUrl" class="img-fluid rounded shadow-sm" style="height:200px; width:100%; object-fit:cover;">
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- SAĞ TARAF: REZERVASYON PANELİ (STICKY) -->
            <div class="col-lg-4">
                <div style="position: sticky; top: 150px; background: white; padding: 30px; border-radius: 20px; box-shadow: 0 15px 50px rgba(0,0,0,0.1); border: 1px solid #eee;">
                    <div class="price-wrap mb-4">
                        <span style="font-size:14px; color:#777;">Kişi Başı Başlayan Fiyatlar</span>
                        <h2 style="color:#1a6b4a; font-weight:800; margin-top:5px;">$@Model.Price.ToString("N0")</h2>
                    </div>
                    
                    <ul class="list-unstyled mb-4">
                        <li class="mb-2"><i class="icon-check-circle" style="color:#1a6b4a; margin-right:10px;"></i> Ücretsiz İptal</li>
                        <li class="mb-2"><i class="icon-check-circle" style="color:#1a6b4a; margin-right:10px;"></i> Rezervasyon Anında Onay</li>
                        <li class="mb-2"><i class="icon-check-circle" style="color:#1a6b4a; margin-right:10px;"></i> En İyi Fiyat Garantisi</li>
                    </ul>

                    @if (Model.Capacity > 0)
                    {
                        <a href="/Booking/Index?tourId=@Model.TourID" 
                           style="display: block; width: 100%; background: #1a6b4a; color: white; text-align: center; padding: 18px; border-radius: 12px; font-weight: 700; text-decoration: none; transition: background 0.3s;"
                           onmouseover="this.style.background='#14543a'" onmouseout="this.style.background='#1a6b4a'">
                           Şimdi Rezervasyon Yap
                        </a>
                    }
                    else
                    {
                        <button disabled style="width: 100%; background: #ccc; color: white; padding: 18px; border-radius: 12px; font-weight: 700; border:none; cursor:not-allowed;">
                           Kontenjan Dolu
                        </button>
                    }
                    
                    <p class="text-center mt-3" style="font-size:12px; color:#999;">Kalan Kontenjan: @Model.Capacity Kişi</p>
                </div>
            </div>
        </div>
    </div>
</section>