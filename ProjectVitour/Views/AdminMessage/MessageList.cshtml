@model List<ProjectVitour.Entities.ContactMessage>
@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title text-navy fw-bold">İletişim Mesajları</h2>
        <p class="text-muted">Kullanıcılardan gelen soruları ve bildirimleri yönetin.</p>
    </div>
</div>

<div class="card border-0 shadow-sm" style="border-radius: 15px; overflow: hidden;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Gönderen</th>
                        <th>Konu</th>
                        <th>Mesaj</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        var rowClass = item.IsRead ? "bg-white" : "table-primary";
                        <tr class="@rowClass">
                            <td class="ps-4">
                                <div class="fw-bold">@item.Name</div>
                                <small class="text-muted">@item.Email</small>
                            </td>
                            <td class="fw-bold">@item.Subject</td>
                            <td><small>@(item.Message.Length > 50 ? item.Message.Substring(0, 50) + "..." : item.Message)</small></td>
                            <td>@item.SendDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>
                                @if (item.IsRead) { <span class="badge bg-secondary">Okundu</span> }
                                else { <span class="badge bg-danger">Yeni</span> }
                            </td>
                            <td class="text-end pe-4">
                                @if (!item.IsRead)
                                {
                                    <a href="/AdminMessage/MarkAsRead/@item.ContactMessageID" class="btn btn-sm btn-outline-success border-0 me-1" title="Okundu İşaretle">
                                        <i class="bi bi-envelope-open"></i>
                                    </a>
                                }
                                <a href="/AdminMessage/DeleteMessage/@item.ContactMessageID" class="btn btn-sm btn-outline-danger border-0" title="Sil" onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>