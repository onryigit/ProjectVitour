@model List<ProjectVitour.Dtos.ReviewDtos.ResultReviewDto>
@{
    ViewData["Title"] = "Yorum Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header">
    <h2 class="page-title">Yorum Yönetimi</h2>
    <p class="text-muted">Müşterilerden gelen tur değerlendirmelerini buradan yönetebilirsiniz.</p>
</div>

<div class="table-card mt-4">
    <table class="table table-hover align-middle mb-0">
        <thead class="bg-light">
            <tr>
                <th class="ps-4">Müşteri</th>
                <th>Yorum Detayı</th>
                <th>Puanlar (R-K-U-K)</th>
                <th>Tarih</th>
                <th>Durum</th>
                <th class="text-end pe-4">İşlemler</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="ps-4">
                        <div class="fw-bold">@item.NameSurname</div>
                    </td>
                    <td><small>@(item.Detail.Length > 50 ? item.Detail.Substring(0, 50) + "..." : item.Detail)</small></td>
                    <td>
                        <span class="badge bg-secondary">R:@item.GuideRating</span>
                        <span class="badge bg-secondary">K:@item.AccommodationRating</span>
                        <span class="badge bg-secondary">U:@item.TransportRating</span>
                        <span class="badge bg-secondary">K:@item.ComfortRating</span>
                    </td>
                    <td>@item.ReviewDate.ToString("dd.MM.yyyy")</td>
                    <td>
                        @if (item.Status) { <span class="badge bg-success-subtle text-success">Yayında</span> }
                        else { <span class="badge bg-warning-subtle text-warning">Beklemede</span> }
                    </td>
                    <td class="text-end pe-4">
                        @if (!item.Status)
                        {
                            <a href="/AdminReview/ApproveReview/@item.ReviewId" class="btn btn-sm btn-outline-success border-0 me-1" title="Onayla">
                                <i class="bi bi-check-circle"></i>
                            </a>
                        }
                        <a href="/AdminReview/ReviewDetails/@item.ReviewId" class="btn btn-sm btn-outline-primary border-0 me-1" title="Detay">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="/AdminReview/DeleteReview/@item.ReviewId" class="btn btn-sm btn-outline-danger border-0" title="Sil" onclick="return confirm('Emin misiniz?')">
                            <i class="bi bi-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>