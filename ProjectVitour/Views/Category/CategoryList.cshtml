@model List<ProjectVitour.Dtos.CategoryDtos.ResultCategoryDto>
@{
    ViewData["Title"] = "Kategori Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center">
    <div>
        <h2 class="page-title">Kategori Yönetimi</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="#">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Kategoriler</li>
            </ol>
        </nav>
    </div>
    <a href="/Category/CreateCategory" class="btn btn-primary" style="border-radius:10px; padding:10px 20px;">
        <i class="bi bi-plus-lg me-2"></i> Yeni Kategori Ekle
    </a>
</div>

<div class="card border-0 shadow-sm mt-4" style="border-radius: 15px; overflow: hidden;">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light">
                    <tr>
                        <th class="ps-4">Kategori Adı</th>
                        <th>Durum</th>
                        <th class="text-end pe-4">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.CategoryName</td>
                            <td>
                                @if(item.CategoryStatus) {
                                    <span class="badge bg-success-subtle text-success p-2">Aktif</span>
                                } else {
                                    <span class="badge bg-secondary-subtle text-secondary p-2">Pasif</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <a href="/Category/DeleteCategory/@item.CategoryId" class="btn btn-sm btn-outline-danger border-0" onclick="return confirm('Emin misiniz?')">
                                    <i class="bi bi-trash-fill"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>