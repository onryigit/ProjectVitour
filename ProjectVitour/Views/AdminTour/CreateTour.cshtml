@model ProjectVitour.Dtos.TourDtos.CreateTourDto
@{
    ViewData["Title"] = "Yeni Tur Ekle";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title text-navy fw-bold">Yeni Tur Oluştur</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/AdminDashboard/Index" class="text-muted text-decoration-none">Admin</a></li>
                <li class="breadcrumb-item"><a href="/AdminTour/TourList" class="text-muted text-decoration-none">Turlar</a></li>
                <li class="breadcrumb-item active fw-bold" aria-current="page">Yeni Ekle</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminTour/TourList" class="btn btn-outline-secondary rounded-pill shadow-sm px-4 fw-bold">
        <i class="bi bi-arrow-left me-2"></i> Listeye Dön
    </a>
</div>

<form asp-action="CreateTour" method="post" id="createTourForm">
    <div class="row g-4 mb-5">
        
        <!-- SOL KOLON (Ana Bilgiler ve Görseller) -->
        <div class="col-lg-8">
            
            <!-- 1. TEMEL BİLGİLER KARTI -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex align-items-center">
                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-info-circle-fill fs-5"></i>
                    </div>
                    <h5 class="fw-bold mb-0 text-dark">Temel Bilgiler</h5>
                </div>
                <div class="card-body p-4">
                    
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tur Adı (Türkçe) <span class="text-danger">*</span></label>
                            <input type="text" asp-for="Title" class="form-control form-control-lg bg-light border-0" required placeholder="Örn: Büyüleyici Kapadokya Turu" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tur Adı (English)</label>
                            <input type="text" asp-for="Title_EN" class="form-control bg-light border-0" placeholder="Örn: Fascinating Cappadocia Tour" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tur Adı (Deutsch)</label>
                            <input type="text" asp-for="Title_DE" class="form-control bg-light border-0" placeholder="Örn: Faszinierende Kappadokien Tour" />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Destinasyon <span class="text-danger">*</span></label>
                            <select asp-for="DestinationID" class="form-select bg-light border-0" required style="cursor: pointer;">
                                <option value="">-- Destinasyon Seçiniz --</option>
                                @if(ViewBag.Destinations != null)
                                {
                                    foreach(var item in ViewBag.Destinations)
                                    {
                                        <option value="@item.DestinationID">@item.CityName, @item.CountryName</option>
                                    }
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Kategori <span class="text-danger">*</span></label>
                            <select asp-for="CategoryID" class="form-select bg-light border-0" required style="cursor: pointer;">
                                <option value="">-- Kategori Seçiniz --</option>
                                @if(ViewBag.Categories != null)
                                {
                                    foreach(var item in ViewBag.Categories)
                                    {
                                        <option value="@item.CategoryId">@item.CategoryName</option>
                                    }
                                }
                            </select>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tur Açıklaması (Türkçe) <span class="text-danger">*</span></label>
                            <textarea asp-for="Description" class="form-control bg-light border-0" rows="4" required placeholder="Tur detaylarını ve hikayesini buraya yazın..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tur Açıklaması (English)</label>
                            <textarea asp-for="Description_EN" class="form-control bg-light border-0" rows="3"></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tur Açıklaması (Deutsch)</label>
                            <textarea asp-for="Description_DE" class="form-control bg-light border-0" rows="3"></textarea>
                        </div>
                    </div>

                </div>
            </div>

            <!-- 2. GÖRSELLER KARTI -->
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex align-items-center">
                    <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-images fs-5"></i>
                    </div>
                    <h5 class="fw-bold mb-0 text-dark">Görseller ve Harita</h5>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted small text-uppercase">Kapak Görseli (URL) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-link-45deg"></i></span>
                                <input type="url" asp-for="CoverImageUrl" id="CoverImageUrlInput" class="form-control bg-light border-0" placeholder="https://source.unsplash.com/..." required />
                            </div>
                            <!-- Mini Önizleme -->
                            <div class="mt-3 text-center bg-light rounded-3 p-3 border border-dashed d-none" id="CoverPreviewContainer">
                                <img id="CoverPreviewImg" src="" alt="Kapak Önizleme" class="img-fluid rounded shadow-sm" style="max-height: 200px; object-fit: cover;" />
                            </div>
                        </div>

                        <div class="col-md-12">
                            <label class="form-label fw-bold text-muted small text-uppercase">Pixar Harita Görseli (URL)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-map"></i></span>
                                <input type="url" asp-for="MapLocationImageUrl" class="form-control bg-light border-0" placeholder="https://..." />
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <!-- SAĞ KOLON (Fiyat, Detaylar ve Kaydet) -->
        <div class="col-lg-4">
            
            <!-- 3. DETAYLAR KARTI -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white border-0 pt-4 pb-0 px-4 d-flex align-items-center">
                    <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-sliders2-vertical fs-5"></i>
                    </div>
                    <h5 class="fw-bold mb-0 text-dark">Fiyat ve Kapasite</h5>
                </div>
                <div class="card-body p-4">
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Fiyat (Kişi Başı) <span class="text-danger">*</span></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-light border-0 fw-bold text-success">$</span>
                            <input type="number" asp-for="Price" class="form-control bg-light border-0 fw-bold text-dark" min="1" step="0.01" required placeholder="0.00" />
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Süre (Gün) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" asp-for="DayCount" class="form-control bg-light border-0" min="1" required />
                                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-clock"></i></span>
                            </div>
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Kapasite <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="number" asp-for="Capacity" class="form-control bg-light border-0" min="1" required />
                                <span class="input-group-text bg-light border-0 text-muted"><i class="bi bi-people"></i></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-bold text-muted small text-uppercase">Tur Rozeti</label>
                        <select asp-for="Badge" class="form-select bg-light border-0 fw-bold text-primary" style="cursor: pointer;">
                            <option value="">Yok</option>
                            <option value="Popüler">Popüler</option>
                            <option value="En Çok Satan">En Çok Satan</option>
                            <option value="Fırsat Ürünü">Fırsat Ürünü</option>
                            <option value="Yeni">Yeni</option>
                            <option value="Sınırlı Kontenjan">Sınırlı Kontenjan</option>
                            <option value="Kültür Turu">Kültür Turu</option>
                        </select>
                    </div>

                </div>
            </div>

            <!-- GİZLİ ALAN -->
            <input type="hidden" asp-for="Location" value="Sistem Otomatik Atayacak" />

            <!-- 4. KAYDET KARTI (Sticky) -->
            <div class="card border-0 shadow-lg rounded-4" style="position: sticky; top: 90px; background: linear-gradient(135deg, #1a6b4a 0%, #11422e 100%);">
                <div class="card-body p-4 text-center">
                    <i class="bi bi-check-circle text-white opacity-50 display-1 mb-3"></i>
                    <h5 class="text-white fw-bold mb-4">Her Şey Hazır Mı?</h5>
                    <button type="submit" class="btn btn-light w-100 py-3 fw-bold rounded-pill text-dark shadow-sm" style="font-size: 1.1rem; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-3px)'" onmouseout="this.style.transform='translateY(0)'">
                        Turu Kaydet ve Yayınla <i class="bi bi-rocket-takeoff ms-2 text-primary"></i>
                    </button>
                    <p class="text-white-50 small mt-3 mb-0">Tur veritabanına eklenir ve anında ön yüzde listelenir.</p>
                </div>
            </div>

        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Görsel URL'si girildiğinde anında önizleme çıkarma
        const coverInput = document.getElementById('CoverImageUrlInput');
        const previewContainer = document.getElementById('CoverPreviewContainer');
        const previewImg = document.getElementById('CoverPreviewImg');

        coverInput.addEventListener('input', function() {
            const url = this.value.trim();
            if(url.startsWith('http')) {
                previewImg.src = url;
                previewContainer.classList.remove('d-none');
            } else {
                previewContainer.classList.add('d-none');
            }
        });
    </script>
}