@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header mb-4">
    <h2 class="page-title text-navy fw-bold">Yönetim Paneli Özeti</h2>
    <p class="text-muted">Hoş geldiniz! Bugün sistemdeki son durum aşağıdadır.</p>
</div>

<div class="row g-4 mb-5">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 text-white rounded-4" style="background: linear-gradient(135deg, #1a6b4a 0%, #11422e 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small mb-2 opacity-75">Toplam Tur</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.TotalTours</h2>
                </div>
                <i class="bi bi-map opacity-50" style="font-size: 2.5rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 text-white rounded-4" style="background: linear-gradient(135deg, #2d9cdb 0%, #1a7ab5 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small mb-2 opacity-75">Toplam Kazanç</h6>
                    <h2 class="fw-bold mb-0">$@ViewBag.TotalEarning.ToString("N0")</h2>
                </div>
                <i class="bi bi-wallet2 opacity-50" style="font-size: 2.5rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 text-white rounded-4" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small mb-2 opacity-75">Bekleyen Rezrv.</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.PendingReservations</h2>
                </div>
                <i class="bi bi-hourglass-split opacity-50" style="font-size: 2.5rem;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-4 text-white rounded-4" style="background: linear-gradient(135deg, #ef4444 0%, #b91c1c 100%);">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h6 class="text-uppercase small mb-2 opacity-75">Yeni Mesajlar</h6>
                    <h2 class="fw-bold mb-0">@ViewBag.UnreadMessages</h2>
                </div>
                <i class="bi bi-envelope-paper opacity-50" style="font-size: 2.5rem;"></i>
            </div>
        </div>
    </div>
</div>

<div class="row mb-5">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">En Çok Rezervasyon Alan Turlar</h5>
            <div style="position: relative; height: 300px; width: 100%;">
                <canvas id="bookingChart"></canvas>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4 h-100">
            <h5 class="fw-bold mb-4">Hızlı İşlemler</h5>
            <div class="d-grid gap-3">
                <a href="/AdminTour/CreateTour" class="btn btn-light border-0 text-start p-3 rounded-3 shadow-sm d-flex align-items-center hover-lift">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-plus-lg"></i>
                    </div>
                    <span class="fw-bold text-dark">Yeni Tur Ekle</span>
                </a>
                <a href="/AdminReservation/ReservationList" class="btn btn-light border-0 text-start p-3 rounded-3 shadow-sm d-flex align-items-center hover-lift">
                    <div class="bg-warning text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    <span class="fw-bold text-dark">Rezervasyonları Yönet</span>
                </a>
                <a href="/AdminMessage/MessageList" class="btn btn-light border-0 text-start p-3 rounded-3 shadow-sm d-flex align-items-center hover-lift">
                    <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 40px; height: 40px;">
                        <i class="bi bi-chat-left-text"></i>
                    </div>
                    <span class="fw-bold text-dark">Mesajları Oku</span>
                </a>
            </div>
            <style>.hover-lift { transition: transform 0.2s; } .hover-lift:hover { transform: translateY(-3px); }</style>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center">
                <h5 class="fw-bold mb-0">Son 5 Rezervasyon</h5>
                <a href="/AdminReservation/ReservationList" class="btn btn-sm btn-outline-primary rounded-pill px-3">Tümünü Gör</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4">Müşteri</th>
                                <th>Tur</th>
                                <th>Tarih</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.LastReservations != null)
                            {
                                var toursList = ViewBag.Tours as List<ProjectVitour.Entities.Tour>;
                                foreach (var item in ViewBag.LastReservations)
                                {
                                    var tourName = toursList?.FirstOrDefault(x => x.TourID == item.TourID)?.Title ?? "Bilinmiyor";
                                    <tr>
                                        <td class="ps-4 fw-bold">@item.FullName</td>
                                        <td><span class="badge bg-info-subtle text-info">@tourName</span></td>
                                        <td>@item.ReservationDate.ToString("dd MMM yyyy")</td>
                                        <td>
                                            @if(item.Status) { <span class="badge bg-success-subtle text-success">Onaylı</span> }
                                            else { <span class="badge bg-warning-subtle text-warning">Beklemede</span> }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('bookingChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(Json.Serialize(ViewBag.ChartLabels)),
                datasets: [{
                    label: 'Rezervasyon Sayısı',
                    data: @Html.Raw(Json.Serialize(ViewBag.ChartData)),
                    backgroundColor: 'rgba(26, 107, 74, 0.8)',
                    borderColor: '#1a6b4a',
                    borderWidth: 1,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { stepSize: 1 }
                    }
                },
                plugins: {
                    legend: { display: false }
                }
            }
        });
    </script>
}