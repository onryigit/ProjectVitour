@model List<ProjectVitour.Dtos.CategoryDtos.ResultCategoryDto>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<ProjectVitour.SharedResource> SharedLocalizer


<div class="mt--82 z-index3 relative">
    <div class="tf-container">
        <div class="row">
            <div class="col-lg-12">
                <div class="search-form-widget-slider relative shadow-lg rounded-4 bg-white p-4" style="border-top: 4px solid #1a6b4a;">
                    <form action="/Tour/TourList" method="get" id="search-form-slider">
                        <div class="row g-3 align-items-center">
                            
                            
                            <div class="col-lg-3 col-md-6">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center transition-all focus-ring focus-ring-success">
                                    <i class="icon-search-2 fs-4 me-3" style="color: #1a6b4a;"></i>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1 text-uppercase" style="letter-spacing: 0.5px;">@SharedLocalizer["AramaYap"]</label>
                                        <input type="text" name="search" class="form-control border-0 p-0 bg-transparent shadow-none" placeholder="@SharedLocalizer["TurAdiVeyaLokasyon"]" value="@Context.Request.Query["search"]" style="font-size: 15px; font-weight: 500;">
                                    </div>
                                </div>
                            </div>

                            
                            <div class="col-lg-3 col-md-6">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center transition-all focus-ring focus-ring-success">
                                    <i class="icon-18 fs-4 me-3" style="color: #1a6b4a;"></i>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1 text-uppercase" style="letter-spacing: 0.5px;">@SharedLocalizer["Kategori"]</label>
                                        <select name="categoryId" class="form-select border-0 p-0 bg-transparent shadow-none fw-bold" style="cursor:pointer; font-size: 15px; color: #112240;">
                                            <option value="">@SharedLocalizer["TumKategoriler"]</option>
                                            @if(Model != null)
                                            {
                                                foreach(var cat in Model)
                                                {
                                                    if(Context.Request.Query["categoryId"] == cat.CategoryId)
                                                    {
                                                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            
                            <div class="col-lg-2 col-md-4">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center transition-all focus-ring focus-ring-success">
                                    <span class="fw-bold fs-4 me-3" style="color: #1a6b4a;">$</span>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1 text-uppercase" style="letter-spacing: 0.5px;">@SharedLocalizer["MinFiyat"]</label>
                                        <input type="number" name="minPrice" class="form-control border-0 p-0 bg-transparent shadow-none" placeholder="0" value="@Context.Request.Query["minPrice"]" style="font-size: 15px; font-weight: 500;">
                                    </div>
                                </div>
                            </div>

                            
                            <div class="col-lg-2 col-md-4">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center transition-all focus-ring focus-ring-success">
                                    <span class="fw-bold fs-4 me-3" style="color: #1a6b4a;">$</span>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1 text-uppercase" style="letter-spacing: 0.5px;">@SharedLocalizer["MaxFiyat"]</label>
                                        <input type="number" name="maxPrice" class="form-control border-0 p-0 bg-transparent shadow-none" placeholder="5000" value="@Context.Request.Query["maxPrice"]" style="font-size: 15px; font-weight: 500;">
                                    </div>
                                </div>
                            </div>

                            
                            <div class="col-lg-2 col-md-4 text-end">
                                <button type="submit" class="btn w-100 py-3 rounded-3 fw-bold text-white shadow-sm" style="background: #1a6b4a; border-color: #1a6b4a; font-size: 16px; transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                                    <i class="icon-Vector5 me-2"></i> @SharedLocalizer["TurlariBul"]
                                </button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
