@model List<ProjectVitour.Dtos.CategoryDtos.ResultCategoryDto>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<ProjectVitour.SharedResource> SharedLocalizer

<!-- Widget Select Form (Search & Filter) -->
<div class="mt--82 z-index3 relative">
    <div class="tf-container">
        <div class="row">
            <div class="col-lg-12">
                <div class="search-form-widget-slider relative shadow-lg rounded-4 bg-white p-4">
                    <form action="/Tour/TourList" method="get" id="search-form-slider">
                        <div class="row g-3 align-items-center">
                            
                            <!-- Arama Kelimesi -->
                            <div class="col-lg-3 col-md-6">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center">
                                    <i class="icon-search-2 text-primary fs-5 me-2"></i>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1">@SharedLocalizer["AramaYap"]</label>
                                        <input type="text" name="search" class="form-control border-0 p-0 bg-transparent" placeholder="Tur adı veya lokasyon..." value="@Context.Request.Query["search"]">
                                    </div>
                                </div>
                            </div>

                            <!-- Kategori Seçimi -->
                            <div class="col-lg-3 col-md-6">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center">
                                    <i class="icon-18 text-primary fs-5 me-2"></i>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1">Kategori</label>
                                        <select name="categoryId" class="form-select border-0 p-0 bg-transparent shadow-none" style="cursor:pointer;">
                                            <option value="">Tüm Kategoriler</option>
                                            @if(Model != null)
                                            {
                                                foreach(var cat in Model)
                                                {
                                                    if(Context.Request.Query["categoryId"] == cat.CategoryId)
                                                    {
                                                        <option value="@cat.CategoryId" selected>@cat.CategoryName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@cat.CategoryId">@cat.CategoryName</option>
                                                    }
                                                }
                                            }
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Minimum Fiyat -->
                            <div class="col-lg-2 col-md-4">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center">
                                    <span class="text-primary fw-bold fs-5 me-2">$</span>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1">Min. Fiyat</label>
                                        <input type="number" name="minPrice" class="form-control border-0 p-0 bg-transparent" placeholder="0" value="@Context.Request.Query["minPrice"]">
                                    </div>
                                </div>
                            </div>

                            <!-- Maksimum Fiyat -->
                            <div class="col-lg-2 col-md-4">
                                <div class="form-group border rounded-3 px-3 py-2 d-flex align-items-center">
                                    <span class="text-primary fw-bold fs-5 me-2">$</span>
                                    <div class="w-100">
                                        <label class="text-muted small fw-bold mb-1">Max. Fiyat</label>
                                        <input type="number" name="maxPrice" class="form-control border-0 p-0 bg-transparent" placeholder="5000" value="@Context.Request.Query["maxPrice"]">
                                    </div>
                                </div>
                            </div>

                            <!-- Arama Butonu -->
                            <div class="col-lg-2 col-md-4 text-end">
                                <button type="submit" class="btn btn-primary w-100 py-3 rounded-3 fw-bold" style="background: #1a6b4a; border-color: #1a6b4a;">
                                    <i class="icon-Vector5 me-2"></i> Turları Bul
                                </button>
                            </div>

                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- End Widget Select Form -->