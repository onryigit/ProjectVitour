@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<ProjectVitour.SharedResource> SharedLocalizer

<footer class="footer footer-style1">
    <div class="tf-container">
        <div class="footer-main">
            <div class="footer-logo">
                <div class="logo-footer">
                    <img src="/vitour/assets/images/logo2.png" alt="">
                </div>
                <p class="des-footer">
                    @SharedLocalizer["AltBilgiAciklama"]
                </p>
                <ul class="footer-info">
                    <li class="flex-three">
                        <i class="icon-noun-mail-5780740-1"></i>
                        <p>info@vitour.com</p>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Group-9"></i>
                        <p>+90 212 555 01 02</p>
                    </li>
                    <li class="flex-three">
                        <i class="icon-Layer-19"></i>
                        <p>Bağdat Caddesi No:123 Kadıköy / İstanbul</p>
                    </li>
                </ul>

            </div>
            <div class="footer-service">
                <h5 class="title">@SharedLocalizer["Kurumsal"]</h5>

                <ul class="footer-menu">
                    <li>
                        <a href="/Home/About">@SharedLocalizer["Hakkimizda"]</a>
                    </li>
                    <li>
                        <a href="/Tour/TourList">@SharedLocalizer["Turlar"]</a>
                    </li>
                    <li>
                        <a href="/Home/Contact">@SharedLocalizer["Iletisim"]</a>
                    </li>
                </ul>
            </div>
            <div class="footer-gallery">
                <h5 class="title">@SharedLocalizer["Galeri"]</h5>

                <div class="gallery-img">
                    <a href="https://images.unsplash.com/photo-1527631746610-bca00a040d60?w=1000&q=80" data-fancybox="gallery">
                        <img src="https://images.unsplash.com/photo-1527631746610-bca00a040d60?w=300&q=80" alt="image gallery" style="object-fit: cover; width: 100%; height: 100%;">
                    </a>
                    <a href="https://images.unsplash.com/photo-1500835556837-99ac94a94552?w=1000&q=80" data-fancybox="gallery">
                        <img src="https://images.unsplash.com/photo-1500835556837-99ac94a94552?w=300&q=80" alt="image gallery" style="object-fit: cover; width: 100%; height: 100%;">
                    </a>
                    <a href="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?w=1000&q=80" data-fancybox="gallery">
                        <img src="https://images.unsplash.com/photo-1499856871958-5b9627545d1a?w=300&q=80" alt="image gallery" style="object-fit: cover; width: 100%; height: 100%;">
                    </a>
                    <a href="https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=1000&q=80" data-fancybox="gallery">
                        <img src="https://images.unsplash.com/photo-1501785888041-af3ef285b470?w=300&q=80" alt="image gallery" style="object-fit: cover; width: 100%; height: 100%;">
                    </a>
                    <a href="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=1000&q=80" data-fancybox="gallery">
                        <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?w=300&q=80" alt="image gallery" style="object-fit: cover; width: 100%; height: 100%;">
                    </a>
                    <a href="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=1000&q=80" data-fancybox="gallery">
                        <img src="https://images.unsplash.com/photo-1476514525535-07fb3b4ae5f1?w=300&q=80" alt="image gallery" style="object-fit: cover; width: 100%; height: 100%;">
                    </a>
                </div>

            </div>
            <div class="footer-newsletter">
                <h5 class="title">@SharedLocalizer["BultenAboneligi"]</h5>
                <form action="/" id="footer-form">
                    <div class="input-wrap flex-three">
                        <input type="email" placeholder="@SharedLocalizer["EpostaGiriniz"]">
                        <button type="submit"><i class="icon-paper-plane"></i></button>
                    </div>
                    <div class="check-form flex-three">
                        <i class="icon-Vector-121"></i>
                        <p>@SharedLocalizer["SartlariKabulEdiyorum"]</p>
                    </div>
                </form>
                <ul class="social-ft flex-three">
                    <li>
                        <a href="#">
                            <i class="icon-icon-2"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-x"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-8"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-2"></i>
                        </a>
                    </li>
                </ul>

            </div>
        </div>

        <div class="row footer-bottom">
            <div class="col-md-6">
                <p class="copy-right">
                    @DateTime.Now.Year Vitour. @SharedLocalizer["TumHaklariSaklidir"]
                    <span style="margin-left: 10px; font-weight: 700; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: linear-gradient(45deg, #ff8a00, #e52e71); -webkit-background-clip: text; -webkit-text-fill-color: transparent; display: inline-block;">
                        @SharedLocalizer["MadeBy"] Yiğit Öner
                    </span>
                </p>
            </div>
            <div class="col-md-6">
                <ul class="social flex-six">
                    <li>
                        <a href="#">
                            <i class="icon-icon-2"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-x"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-icon_03"></i>
                        </a>
                    </li>
                    <li>
                        <a href="#">
                            <i class="icon-2"></i>
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</footer>