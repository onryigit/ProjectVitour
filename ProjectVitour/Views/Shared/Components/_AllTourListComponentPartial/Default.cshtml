@using ProjectVitour.Helpers
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<ProjectVitour.SharedResource> SharedLocalizer
@model List<ProjectVitour.Dtos.TourDtos.ResultTourDto>

<style>
    .tour-listing-image {
        position: relative;
        display: block;
        overflow: hidden;
        border-radius: 16px 16px 0 0;
    }
    .tour-listing-image img {
        width: 100% !important;
        height: 250px !important;
        object-fit: cover !important;
        transition: transform 0.5s ease;
    }
    .tour-listing:hover .tour-listing-image img {
        transform: scale(1.08);
    }
    /* Premium Glassmorphism Badge */
    .premium-badge {
        position: absolute;
        top: 15px;
        left: 15px;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: #fff;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 700;
        z-index: 10;
        text-shadow: 0 1px 3px rgba(0,0,0,0.3);
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
</style>

<section class="archieve-tour">
    <div class="tf-container">
        <div class="listing-list-car-wrap listing-list-car-wrap-grid3">

            <form action="/" class="tf-my-listing mb-37">
                <div class="row align-center">
                    <div class="col-sm-5">
                        @{
                            // Eğer ViewBag verileri boş gelirse hata vermemesi için güvenli atamalar
                            int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
                            int pageSize = ViewBag.PageSize != null ? (int)ViewBag.PageSize : 6;
                            long totalCount = ViewBag.TotalCount != null ? (long)ViewBag.TotalCount : Model.Count;
                            int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;

                            int startItem = ((currentPage - 1) * pageSize) + 1;
                            long endItem = startItem + Model.Count - 1;

                            if (totalCount == 0)
                            {
                                startItem = 0;
                                endItem = 0;
                            }
                        }
                        <p class="showing">Gösteriliyor: <span class="text-main">@startItem - @endItem</span> of @totalCount Results</p>
                    </div>
                    <div class="col-sm-7  flex-six group-bar-wrap">
                        <div class="listing-all-wrap">
                            <div class="flex-three">
                                <div class="group-select-recently">
                                    <div class="nice-select" tabindex="0">
                                        <i class="icon-Vector6"></i><span class="current">Price</span>
                                        <ul class="list">
                                            <li data-value="" class="option selected focus">Price</li>
                                            <li data-value="new" class="option">New</li>
                                            <li data-value="Recently Added" class="option">Recently Added</li>
                                        </ul>
                                    </div>
                                </div>
                                <div class="toolbar-list">
                                    <div class="form-group">
                                        <a class="btn-display-listing-grid">
                                            <i class="icon-list"></i>
                                        </a>
                                    </div>
                                    <div class="form-group">
                                        <a class="btn-display-listing-list active">
                                            <i class="icon-Group-1000001297"></i>
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </form>

            <div class="listing-list-car-grid mb-60">
                @foreach (var item in Model)
                {
                    var localizedTitle = LocalizationHelper.GetLocalizedText(item.Title, item.Title_EN, item.Title_DE);
                    var localizedPrice = LocalizationHelper.GetLocalizedPrice(item.Price);
                    
                    <div class="tour-listing box-sd" style="border-radius: 16px; transition: box-shadow 0.3s;">
                        <a href="/Tour/Details/@item.TourID" class="tour-listing-image">
                            <span class="premium-badge">@item.Badge</span>
                            <img src="@item.CoverImageUrl" alt="@localizedTitle">
                        </a>
                        <div class="tour-listing-content" style="padding: 24px;">
                            <span class="map" style="color:#64748b; font-size:13px;"><i class="icon-Vector4"></i> @item.Location</span>
                            <h3 class="title-tour-list" style="margin-top:8px; margin-bottom:15px; font-weight:700;">
                                <a href="/Tour/Details/@item.TourID">
                                    @localizedTitle
                                </a>
                            </h3>
                            <div class="icon-box flex-three" style="border-bottom: 1px solid #f1f5f9; padding-bottom:15px; margin-bottom:15px;">
                                <div class="icons flex-three">
                                    <i class="icon-time-left" style="color:#1a6b4a;"></i>
                                    <span style="font-weight:600;">@item.DayCount @SharedLocalizer["Gun"]</span>
                                </div>
                                <div class="icons flex-three">
                                    <i class="icon-user" style="color:#1a6b4a; margin-right:5px;"></i>
                                    <span style="font-weight:600;">@item.Capacity @SharedLocalizer["Kisi"]</span>
                                </div>
                            </div>
                            <div class="flex-two align-center">
                                <div class="price-box">
                                    <span style="color:#64748b; font-size:12px; display:block;">@SharedLocalizer["Fiyat"]</span>
                                    <span class="price" style="font-size:22px; font-weight:800; color:#1a6b4a;">@localizedPrice</span>
                                </div>
                                <a href="/Tour/Details/@item.TourID" class="btn btn-sm" style="background:#1a6b4a; color:#fff; border-radius:8px; padding:8px 16px;">
                                    @SharedLocalizer["DetaylariGor"]
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="row">
                <div class="col-md-12">
                    <ul class="tf-pagination flex-five mt-20">
                        @{
                            // Sayfalama değişkenleri yukarıda atanmıştı
                            int currentPg = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
                            int totalPgs = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
                        }

                        @if (currentPg > 1)
                        {
                            <li>
                                <a class="pages-link" href="?page=@(currentPg - 1)"> <i class="icon-29"></i></a>
                            </li>
                        }

                        @for (int i = 1; i <= totalPgs; i++)
                        {
                            if (i == currentPg)
                            {
                                <li class="pages-item active" aria-current="page">
                                    <a class="pages-link" href="#">@i</a>
                                </li>
                            }
                            else
                            {
                                <li>
                                    <a class="pages-link" href="?page=@i">@i</a>
                                </li>
                            }
                        }

                        @if (currentPg < totalPgs)
                        {
                            <li>
                                <a class="pages-link" href="?page=@(currentPg + 1)"><i class="icon--1"></i></a>
                            </li>
                        }
                    </ul>
                </div>
            </div>

        </div>
    </div>
</section>