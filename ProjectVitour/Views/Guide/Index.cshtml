@model List<ProjectVitour.Entities.Guide>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IHtmlLocalizer<ProjectVitour.SharedResource> SharedLocalizer
@{
    ViewData["Title"] = SharedLocalizer["Rehberlerimiz"];
    Layout = "~/Views/Shared/_VitourLayout.cshtml";
}

<section class="team-section" style="margin-top: 130px; padding: 60px 0;">
    <div class="container">
        <div class="row mb-5">
            <div class="col-12 text-center">
                <h2 class="fw-bold" style="color: #1a6b4a;">@SharedLocalizer["Rehberlerimiz"]</h2>
                <p class="text-muted mt-2">Alanında uzman, deneyimli tur rehberlerimizle tanışın.</p>
            </div>
        </div>
        <div class="row g-4">
            @if (Model != null && Model.Any())
            {
                foreach (var guide in Model)
                {
                    <div class="col-lg-3 col-md-6">
                        <div class="card border-0 shadow-sm text-center rounded-4 overflow-hidden h-100" style="transition: transform 0.3s; cursor: pointer;" onmouseover="this.style.transform='translateY(-10px)'" onmouseout="this.style.transform='translateY(0)'">
                            <div class="position-relative">
                                <img src="@guide.ImageUrl" alt="@guide.FullName" class="card-img-top" style="height: 280px; object-fit: cover;">
                            </div>
                            <div class="card-body p-4">
                                <h5 class="fw-bold mb-1" style="color: #112240;">@guide.FullName</h5>
                                <p class="text-muted small mb-3">@guide.Title</p>
                                <div class="d-flex justify-content-center gap-2">
                                    @if (!string.IsNullOrEmpty(guide.InstagramUrl))
                                    {
                                        <a href="@guide.InstagramUrl" target="_blank" class="btn btn-light rounded-circle text-danger" style="width:40px; height:40px; line-height:26px;"><i class="bi bi-instagram"></i></a>
                                    }
                                    @if (!string.IsNullOrEmpty(guide.TwitterUrl))
                                    {
                                        <a href="@guide.TwitterUrl" target="_blank" class="btn btn-light rounded-circle text-info" style="width:40px; height:40px; line-height:26px;"><i class="bi bi-twitter-x"></i></a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-person-badge text-muted opacity-50" style="font-size: 4rem;"></i>
                    <p class="mt-3 text-muted">Henüz kayıtlı bir rehber bulunmuyor.</p>
                </div>
            }
        </div>
    </div>
</section>