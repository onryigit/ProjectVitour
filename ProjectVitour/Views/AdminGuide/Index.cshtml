@model List<ProjectVitour.Entities.Guide>
@{
    ViewData["Title"] = "Rehber Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title text-navy fw-bold">Rehber Yönetimi</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/AdminDashboard/Index" class="text-muted">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rehberler</li>
            </ol>
        </nav>
    </div>
    <a href="/AdminGuide/CreateGuide" class="btn btn-primary rounded-3 shadow-sm">
        <i class="bi bi-plus-lg me-2"></i> Yeni Rehber Ekle
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
    <div class="card-header bg-white p-4 border-0">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-people text-primary me-2"></i> Tur Rehberleri Listesi</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Rehber Profili</th>
                        <th class="py-3">Sosyal Medya</th>
                        <th class="py-3">Durum</th>
                        <th class="text-end pe-4 py-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null)
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center" style="width:45px; height:45px;">
                                            <i class="bi bi-person text-muted"></i>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-1">@item.FullName</div>
                                            <small class="text-muted">@item.Title</small>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3 text-muted">
                                    <a href="@item.InstagramUrl" target="_blank" class="text-muted me-2"><i class="bi bi-instagram"></i></a>
                                    <a href="@item.TwitterUrl" target="_blank" class="text-muted"><i class="bi bi-twitter-x"></i></a>
                                </td>
                                <td class="py-3">
                                    @if(item.Status) {
                                        <a href="/AdminGuide/ToggleStatus/@item.GuideID" class="badge bg-success-subtle text-success p-2 rounded-pill text-decoration-none">Aktif <i class="bi bi-toggle-on ms-1"></i></a>
                                    } else {
                                        <a href="/AdminGuide/ToggleStatus/@item.GuideID" class="badge bg-secondary-subtle text-secondary p-2 rounded-pill text-decoration-none">Pasif <i class="bi bi-toggle-off ms-1"></i></a>
                                    }
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="btn-group">
                                        <a href="#" class="btn btn-sm btn-light text-warning shadow-sm"><i class="bi bi-pencil-fill"></i></a>
                                        <a href="/AdminGuide/DeleteGuide/@item.GuideID" class="btn btn-sm btn-light text-danger shadow-sm" onclick="return confirm('Emin misiniz?')"><i class="bi bi-trash-fill"></i></a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people text-muted opacity-50" style="font-size: 4rem;"></i>
                <h6 class="mt-3 text-muted fw-bold">Kayıtlı Rehber Yok</h6>
            </div>
        }
    </div>
</div>