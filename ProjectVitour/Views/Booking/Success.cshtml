@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rezervasyon Başarılı - Vitour</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body { font-family: 'Inter', sans-serif; }
    </style>
</head>
<body class="bg-gray-50 flex items-center justify-center min-h-screen">

    <div class="max-w-xl w-full bg-white shadow-2xl rounded-3xl overflow-hidden m-4 text-center p-12">
        <div class="w-24 h-24 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-6">
            <i class="bi bi-check-lg text-5xl text-emerald-600"></i>
        </div>
        
        <h1 class="text-3xl font-bold text-gray-800 mb-4">Rezervasyon Başarılı!</h1>
        <p class="text-gray-500 mb-6 leading-relaxed">
            Harika bir seçim yaptınız. Biletiniz ve tur detaylarınız e-posta adresinize gönderildi. Müşteri temsilcilerimiz ödeme onayı için en kısa sürede sizinle iletişime geçecektir.
        </p>

        @if(TempData["ReservationCode"] != null)
        {
            <div class="bg-emerald-50 border-2 border-dashed border-emerald-400 rounded-2xl p-6 mb-6 mt-2">
                <p class="text-emerald-800 text-sm uppercase tracking-wider font-semibold mb-2">Rezervasyon Kodunuz</p>
                <div class="text-4xl font-extrabold text-emerald-600 tracking-widest">@TempData["ReservationCode"]</div>
            </div>

            <div class="bg-amber-50 border-l-4 border-amber-500 p-4 mb-8 text-left rounded-r-lg shadow-sm">
                <div class="flex items-start">
                    <div class="flex-shrink-0">
                        <i class="bi bi-info-circle-fill text-amber-500 text-xl"></i>
                    </div>
                    <div class="ml-3">
                        <p class="text-sm text-amber-800 leading-relaxed">
                            <strong>Bilgilendirme:</strong> Herhangi bir destek ihtiyacınızda veya rezervasyonunuzla ilgili değişiklik taleplerinizde, size özel oluşturulan bu <strong>@TempData["ReservationCode"]</strong> referans kodu ile müşteri hizmetlerimizden öncelikli ve kesintisiz yardım alabilirsiniz.
                        </p>
                    </div>
                </div>
            </div>
        }

        <div class="bg-gray-50 rounded-2xl p-6 mb-8 text-left border border-gray-100">
            <h3 class="font-semibold text-gray-700 mb-2">Sırada ne var?</h3>
            <ul class="text-sm text-gray-500 space-y-2">
                <li class="flex items-center"><i class="bi bi-dot text-emerald-500 text-xl"></i> E-posta kutunuzu (ve gerekiyorsa spam klasörünü) kontrol edin.</li>
                <li class="flex items-center"><i class="bi bi-dot text-emerald-500 text-xl"></i> Valizinizi hazırlamaya başlayın!</li>
            </ul>
        </div>

        <a href="/Tour/TourList" class="inline-block bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-4 px-8 rounded-xl shadow-lg hover:shadow-emerald-200 transition-all transform hover:-translate-y-1">
            Ana Sayfaya Dön
        </a>
    </div>

</body>
</html>