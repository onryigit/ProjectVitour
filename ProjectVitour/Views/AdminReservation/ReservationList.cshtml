@model List<ProjectVitour.Dtos.ReservationDtos.ResultReservationDto>
@{
    ViewData["Title"] = "Rezervasyon Listesi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var tours = ViewBag.Tours as List<ProjectVitour.Dtos.TourDtos.ResultTourDto>;
}

<div class="page-header d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="page-title text-navy fw-bold">Rezervasyon Yönetimi</h2>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/AdminDashboard/Index" class="text-muted">Admin</a></li>
                <li class="breadcrumb-item active" aria-current="page">Rezervasyonlar</li>
            </ol>
        </nav>
    </div>
    <div class="d-flex gap-2">
        <a href="/AdminReservation/ExportToExcel" class="btn btn-success rounded-3 shadow-sm">
            <i class="bi bi-file-earmark-excel me-2"></i> Excel Olarak İndir
        </a>
        <a href="/AdminReservation/ExportToPdf" class="btn btn-danger rounded-3 shadow-sm">
            <i class="bi bi-file-earmark-pdf me-2"></i> PDF Olarak İndir
        </a>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5">
    <div class="card-header bg-white p-4 border-0 d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0 fw-bold"><i class="bi bi-calendar2-check text-primary me-2"></i> Gelen Tüm Rezervasyonlar</h5>
        <div class="d-flex gap-3">
            <div class="position-relative">
                <i class="bi bi-search position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                <input type="text" id="resSearch" class="form-control rounded-pill ps-5 bg-light border-0" placeholder="Müşteri veya Tur Ara..." style="width:250px;">
            </div>
            <select id="resStatusFilter" class="form-select rounded-pill bg-light border-0" style="width:140px; cursor:pointer;">
                <option value="">Tümü</option>
                <option value="Onaylı">Onaylı</option>
                <option value="Beklemede">Beklemede</option>
            </select>
        </div>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="resTable">
                <thead class="bg-light text-muted small text-uppercase">
                    <tr>
                        <th class="ps-4 py-3">Müşteri</th>
                        <th class="py-3">Seçilen Tur</th>
                        <th class="py-3">Kişi</th>
                        <th class="py-3">Tarih</th>
                        <th class="py-3">Durum</th>
                        <th class="text-end pe-4 py-3">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if(Model != null)
                    {
                        foreach (var item in Model)
                        {
                            var tourName = tours?.FirstOrDefault(x => x.TourID?.ToString() == item.TourID?.ToString())?.Title ?? "Bilinmiyor";
                            var reservationCode = !string.IsNullOrWhiteSpace(item.ReservationCode)
                                ? item.ReservationCode
                                : (!string.IsNullOrWhiteSpace(item.ReservationID)
                                    ? "#VIT-" + item.ReservationID.Substring(Math.Max(0, item.ReservationID.Length - 5)).ToUpper()
                                    : "-");
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold shadow-sm" style="width:42px; height:42px; font-size:16px;">
                                            @item.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <div class="ms-3">
                                            <div class="fw-bold text-dark mb-1">@item.FullName</div>
                                            <small class="text-muted"><i class="bi bi-envelope me-1"></i>@item.Email</small>
                                            <div><small class="text-secondary">Kod: <span class="fw-semibold">@reservationCode</span></small></div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3"><span class="badge bg-light text-dark border p-2">@tourName</span></td>
                                <td class="py-3"><span class="fw-bold">@item.PersonCount</span> Kişi</td>
                                <td class="py-3 text-muted">@item.ReservationDate.ToString("dd MMM yyyy HH:mm")</td>
                                <td class="py-3 status-cell">
                                    @if(item.Status) {
                                        <span class="badge bg-success-subtle text-success p-2 rounded-pill"><i class="bi bi-check-circle me-1"></i> Onaylı</span>
                                    } else {
                                        <span class="badge bg-warning-subtle text-warning p-2 rounded-pill"><i class="bi bi-hourglass-split me-1"></i> Beklemede</span>
                                    }
                                </td>
                                <td class="text-end pe-4 py-3">
                                    <div class="d-flex justify-content-end gap-2 flex-wrap action-buttons">
                                        <a class="btn-action btn-excel" href="/AdminReservation/ExportToExcelById/@item.ReservationID" title="Excel İndir">
                                            <i class="bi bi-file-earmark-excel-fill"></i>
                                        </a>
                                        <a class="btn-action btn-pdf" href="/AdminReservation/ExportToPdfById/@item.ReservationID" title="PDF İndir">
                                            <i class="bi bi-file-earmark-pdf-fill"></i>
                                        </a>
                                        <a class="btn-action btn-delete" href="/AdminReservation/DeleteReservation/@item.ReservationID" title="Sil" onclick="return confirm('Bu rezervasyonu silmek istediğinize emin misiniz?')">
                                            <i class="bi bi-trash-fill"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
        @if (Model == null || !Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox text-muted opacity-50" style="font-size: 5rem;"></i>
                <h5 class="mt-3 text-muted fw-bold">Henüz hiç rezervasyon bulunmuyor.</h5>
                <p class="text-muted small">Yeni rezervasyonlar geldiğinde burada listelenecektir.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('resSearch').addEventListener('keyup', function() {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('#resTable tbody tr');
            rows.forEach(row => {
                let text = row.innerText.toLowerCase();
                row.style.display = text.includes(filter) ? '' : 'none';
            });
        });

        document.getElementById('resStatusFilter').addEventListener('change', function() {
            let filter = this.value.toLowerCase();
            let rows = document.querySelectorAll('#resTable tbody tr');
            rows.forEach(row => {
                if (filter === "") {
                    row.style.display = '';
                } else {
                    let statusText = row.querySelector('.status-cell').innerText.toLowerCase();
                    row.style.display = statusText.includes(filter) ? '' : 'none';
                }
            });
        });
    </script>
}

<style>
    .action-buttons .btn-action {
        width: 34px;
        height: 34px;
        border: none;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 15px;
        cursor: pointer;
        transition: all .15s;
        text-decoration: none;
    }

    .action-buttons .btn-action:hover {
        transform: translateY(-1px);
    }

    .action-buttons .btn-excel {
        background: #dcfce7;
        color: #15803d;
    }

    .action-buttons .btn-excel:hover {
        background: #bbf7d0;
        color: #166534;
    }

    .action-buttons .btn-pdf {
        background: #e0f2fe;
        color: #0369a1;
    }

    .action-buttons .btn-pdf:hover {
        background: #bae6fd;
        color: #075985;
    }

    .action-buttons .btn-delete {
        background: #fee2e2;
        color: #991b1b;
    }

    .action-buttons .btn-delete:hover {
        background: #fecaca;
        color: #7f1d1d;
    }
</style>
